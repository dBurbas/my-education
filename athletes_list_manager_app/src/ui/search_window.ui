  <property name="styleSheet">
   <string notr="true">QDialog {
	background-color: palette(base);
}
QLabel {
	margin-left: 0.1em;
}
QFrame {
	border:none;
	color: palette(text);
}
/*--------- Main part ---------*/
QLabel#table_name_label {
	font: 15pt &quot;Inter&quot;;
}
QLabel#file_name_label {
	font: 14pt &quot;Inter&quot;;
	color: palette(text);
}
QFrame#table_head {
	background-color: palette(base);
}
QFrame#table_head QPushButton{
	padding: 0 0.9em;
	padding-left: 0.7em;
	text-align:left;
}
QFrame#table_part {
	border: 2px solid palette(midlight);
	border-radius: 1em;
	background-color: palette(base);
	margin: 0 1em;
}
QFrame#table_part QFrame#pagination {
	border-top: 2px solid palette(midlight);
	border-bottom-left-radius: 10%;
	border-bottom-right-radius: 10%;
}

QFrame#fields {
	background-color: palette(base);
}
QPushButton {
	padding:10px;
	background-color: palette(button) ;
	border-radius: 12%;
	color: palette(button-text);
}
QLineEdit {
	border-radius: 7%;
	padding: 0 0.4em;
	background-color: palette(button);
}
QLineEdit:focus {
	border: 2px solid #76f725; 
}
QSpinBox {
	border-radius: 7%;
	padding: 0.2em;
}
QPushButton:hover {
	background-color: palette(highlight);
}
QPushButton:pressed {
	background-color: #76f725;
	color: palette(shadow);
}
QComboBox {
    border: 2px solid palette(button); 
    border-radius: 7%;
    padding: 2px 5px;
}
QComboBox::drop-down {
    background-color: palette(alternate-base); 
    
    border-left: 2px solid palette(midlight);
    border-top-right-radius: 5%;
    border-bottom-right-radius: 5%;
    
    width: 25px; 
}
QComboBox::down-arrow {
    image: url(&quot;/Users/dmitryburbas/Documents/Education/github_education_repo/my-education/athletes_list_manager_app/src/images/combo-icon.png&quot;);
    width: 16px;
    height: 16px;
}
QComboBox::drop-down:on {
    background-color:#76f725;
}
QComboBox:focus {
    border: 2px solid #76f725; 
}
QComboBox::drop-down:disabled {
    background-color:palette(button);
}
QComboBox:disabled {
	background-color:palette(button);
}


QComboBox::drop-down:hover {
    background-color:#76f725;
}
QSpinBox {
    padding-right: 15px;
	padding-left: 0.3em;
    border: 1px solid palette(midlight);
    border-radius: 7%;
    background-color: palette(base);
    color: palette(text);
}

QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right; 
    width: 25px; 
    
    background-color: palette(alternate-base);
    border-left: 1px solid  palette(base);
    border-top-right-radius: 5%;
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 25px;
    
    background-color: palette(alternate-base);
	border-top: 1px solid  palette(base);
    border-left: 1px solid palette(base);
    border-bottom-right-radius: 5%;
}

QSpinBox::up-arrow {
    image: url(&quot;/Users/dmitryburbas/Documents/Education/github_education_repo/my-education/athletes_list_manager_app/src/images/up-arrow.png&quot;);
    width: 14px;
    height: 14px;
}

QSpinBox::down-arrow {
    image: url(&quot;/Users/dmitryburbas/Documents/Education/github_education_repo/my-education/athletes_list_manager_app/src/images/down-arrow.png&quot;);
    width: 14px;
    height: 14px;
}
QSpinBox::up-button:hover,QSpinBox::down-button:hover {
    background-color: #76f725;
}
QSpinBox::up-button:pressed,QSpinBox::down-button:pressed {
    background-color: #48b007;
}
QFrame#sidebar {
	border-radius: 15%;
	border: 2px solid palette(button);
}</string>
