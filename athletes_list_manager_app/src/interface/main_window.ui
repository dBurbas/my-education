  <property name="styleSheet">
   <string notr="true">/*--------- General ---------*/
QMainWindow {
	background-color: #FFFFFF;
}
QStatusBar {
	background-color: #FFFFFF;
}
QFrame#main_part {
	background-color: #F3F7FF;
	font-family: &quot;Inter&quot;, sans-serif;
	font-size: 14pt;
	border: none;
}
QFrame {
	border:none;
	color: #375C78;
}
QPushButton {
	background-color: #F3F7FF;
	border-radius: 12%;
	color: #375C78;
}
QPushButton:hover {
	background-color: #E8ECF3;
}
QPushButton:pressed {
	background-color: #f08700;
	color: #ffffff;
}
/*--------- Main part ---------*/
QLabel#table_name_label {
	font: 15pt &quot;Inter&quot;;
}
QLabel#file_name_label {
	font: 14pt &quot;Inter&quot;;
	color: #A2ACBF;
}
QFrame#table_head {
	background-color: #ffffff;
}
QFrame#table_head QPushButton{
	padding: 0 0.9em;
	padding-left: 0.7em;
	text-align:left;
}
QFrame#table_part {
	border: 2px solid #E3E9F5;
	border-radius: 1em;
	background-color: #ffffff;
	margin: 0 1em;
}
QFrame#table_part QFrame#pagination {
	border-top: 2px solid #E3E9F5;
	border-bottom-left-radius: 10%;
	border-bottom-right-radius: 10%;
}
/*--------- Sidebar ---------*/
QFrame#sidebar {
	background-color: #ffffff;
	border-right: 2px solid #E3E9F5;
}
QLabel#app_label {
	font: bold italic 24pt &quot;Gill Sans&quot;; 
}
QFrame#sidebar QPushButton {
	background-color: #F3F7FF;
	border-top-left-radius: 0;
	border-bottom-left-radius: 0;
	border-top-right-radius: 1em;
	border-bottom-right-radius: 1em;
	font: 14pt;
	text-align: left;
	padding-left: 1.5em;
}
QFrame#sidebar QPushButton:hover {
	background-color: #E8ECF3;
	font-weight: bold;
}
QFrame#sidebar QPushButton:pressed {
	background-color: #f08700;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#add_button:hover {
	background-color: #09D65F;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#add_button:pressed {
	background-color: #0CAB4E;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#delete_button:hover {
	background-color: #FF6C6C;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#delete_button:pressed {
	background-color: #D35656;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#search_button:hover {
	background-color: #56AAFF;
	color: #ffffff;
	font-weight: bold;
}
QFrame#sidebar QPushButton#search_button:pressed {
	background-color: #3D91E4;
	color: #ffffff;
	font-weight: bold;
}</string>
